# RevenueCat public SDK keys for the mobile in-app "unlock all sizes" purchase.
# Get these from the RevenueCat dashboard (Project settings > API keys).
# These are PUBLIC keys (safe to ship in the client bundle); do NOT use the
# secret/server key here. Copy this file to .env and fill in real values.
#
# Web/desktop builds ignore these — they are always fully unlocked.
VITE_RC_IOS_KEY=
VITE_RC_ANDROID_KEY=
