{
  "name": "jigsaw",
  "version": "1.0.0",
  "description": "Jigsaw: Your photos, your puzzle — turn any photo into a jigsaw puzzle.",
  "author": "Colt Callaghan",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:browser": "vite",
    "build:web": "node scripts/gen-legal-html.mjs && vite build -c vite.web.config.ts",
    "gen:legal": "node scripts/gen-legal-html.mjs",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-builder",
    "package:win": "electron-builder --win",
    "package:mac": "electron-builder --mac",
    "package:linux": "electron-builder --linux",
    "sync:mobile": "npm run build:web && npx cap sync",
    "open:ios": "npx cap open ios",
    "open:android": "npx cap open android",
    "check:audio": "node scripts/check-audio.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "fake-indexeddb": "^6.2.5",
    "playwright": "^1.60.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "@fontsource/baloo-2": "^5.2.7",
    "@fontsource/jersey-10": "^5.2.8",
    "@fontsource/nunito": "^5.2.7",
    "@fontsource/plus-jakarta-sans": "^5.2.8",
    "@fontsource/press-start-2p": "^5.2.7",
    "@fontsource/space-grotesk": "^5.2.10",
    "@pixi/assets": "^7.4.0",
    "@revenuecat/purchases-capacitor": "^13.1.4",
    "pixi.js": "^8.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "steamworks.js": "^0.4.0"
  },
  "build": {
    "appId": "com.coltcallaghan.jigsaw",
    "productName": "Jigsaw",
    "afterPack": "scripts/afterPack.cjs",
    "directories": {
      "output": "release"
    },
    "asarUnpack": [
      "**/node_modules/steamworks.js/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "resources/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "resources/icon.icns",
      "category": "public.app-category.games",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "NSHumanReadableCopyright": "© Colt Callaghan",
        "CFBundleDisplayName": "Jigsaw: Your photos, your puzzle"
      }
    },
    "dmg": {
      "writeUpdateInfo": false
    }
  }
}
